# ───────────────────────────────────────────────────────────────
#  njs Florist — environment variables
#  Copy this file to `.env.local` for local dev, and configure the
#  same keys in the Vercel project dashboard for production.
# ───────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
# Public origin of the deployed app (no trailing slash).
# Vercel previews will fall back to https://$VERCEL_URL if unset.
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Database (Postgres / Supabase) ─────────────────────────────
# Pooled connection string (pgbouncer) — used by Prisma at runtime.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (no pooling) — used by `prisma migrate`.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── Supabase (optional, client + server) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Clerk auth (optional) ──────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SIGNING_SECRET=""

# ── Midtrans (payments) ────────────────────────────────────────
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
MIDTRANS_SERVER_KEY=""
MIDTRANS_MERCHANT_ID=""
# "true" only in production
MIDTRANS_IS_PRODUCTION="false"

# ── WhatsApp (Fonnte or none) ──────────────────────────────────
WHATSAPP_PROVIDER="none"
WHATSAPP_API_TOKEN=""
WHATSAPP_ADMIN_NUMBER=""

# ── Cloudinary (product images) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Resend (transactional email) ───────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="orders@your-domain.com"

# ── Misc ───────────────────────────────────────────────────────
LOW_STOCK_ALERT_EMAIL=""
CRON_SECRET=""
CALENDAR_FEED_SECRET=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
